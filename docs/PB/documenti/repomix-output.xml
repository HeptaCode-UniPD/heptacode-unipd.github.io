  "StartAt": "Initialize",
  "QueryLanguage": "JSONata",
  "States": {
    "Initialize": {
      "Type": "Pass",
      "Assign": {
        "jobId": "{% $states.input.jobId %}",
        "repoUrl": "{% $states.input.repoUrl %}",
        "commitSha": "{% $states.input.commitSha %}",
        "s3Prefix": "{% 'repos/' & $states.input.jobId %}"
      },
      "Next": "MainAnalysisProcess"
    },

    "MainAnalysisProcess": {
      "Type": "Parallel",
      "Branches": [
        {
          "StartAt": "Pull Repo to S3",
          "States": {
            "Pull Repo to S3": {
              "Type": "Task",
              "Resource": "arn:aws:states:::lambda:invoke",
              "Arguments": {
                "FunctionName": "arn:aws:lambda:${aws:region}:${aws:accountId}:function:ms2-analysis-service-${sls:stage}-pullRepoToS3",
                "Payload": {
                  "jobId": "{% $jobId %}",
                  "repoUrl": "{% $repoUrl %}",
                  "commitSha": "{% $commitSha %}",
                  "s3Prefix": "{% $s3Prefix %}"
                }
              },
              "Retry": [
                {
                  "ErrorEquals": [
                    "Lambda.TooManyRequestsException",
                    "States.TaskFailed"
                  ],
                  "IntervalSeconds": 2,
                  "MaxAttempts": 3
                }
              ],
              "Assign": {
                "s3Bucket": "{% $states.result.Payload.s3Bucket %}",
                "s3Key": "{% $states.result.Payload.s3Key %}",
                "repoMetadata": "{% $states.result.Payload.repoMetadata %}",
                "resolvedCommitSha": "{% $states.result.Payload.commitSha %}"
              },
              "Next": "Orchestrator Planning"
