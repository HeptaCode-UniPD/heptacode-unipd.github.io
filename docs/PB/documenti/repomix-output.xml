    const fakeBody = { pipe: jest.fn() };
    mockSend.mockResolvedValue({ Body: fakeBody });

    await executeUnzipRepo({ bucket: 'my-bucket', zipKey: 'path/to/repo.zip' });

    expect(GetObjectCommand).toHaveBeenCalledWith({
