        "Payload": "{% $states.input %}"
      },
      "Next": "Fail Execution"
    },

    "Fail Execution": {
      "Type": "Fail",
      "Error": "AnalysisFailed",
      "Cause": "L'analisi è terminata con un errore."
    },
    "Success": { "Type": "Succeed" }
  }
}
